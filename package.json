    "start": "node dist/src/index.js",
    "dev": "ts-node src/index.ts",
    "clean": "rimraf dist"
  },
  "keywords": [
    "mcp",
    "microsoft",
    "ai",
    "copilot",
    "azure-ai",
    "github",
    "claude",
    "newsletter"
