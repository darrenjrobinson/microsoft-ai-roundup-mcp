# Required for running the ingestion pipeline (and optional for the server's semantic search)
OPENAI_API_KEY=sk-...

# Optional: Override the output database path for ingestion (default: ./microsoft-ai-roundup.db)
# INGEST_DB_PATH=/path/to/microsoft-ai-roundup.db

# Optional: Point the MCP server at a local database instead of downloading from GitHub Releases
# MSAI_ROUNDUP_DB_PATH=/path/to/microsoft-ai-roundup.db
